@page "/attachments"
@using MailQueueNet.Grpc

<PageTitle>Attachments</PageTitle>

<MudContainer MaxWidth="MaxWidth.False">
    <div class="d-flex justify-space-between align-center mb-3 flex-wrap gap-2">
        <MudText Typo="Typo.h5">Attachments</MudText>
        <div class="d-flex align-center gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="this.RefreshAsync" Disabled="this.busy">Refresh</MudButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(this.error))
    {
        <MudAlert Severity="Severity.Warning">@this.error</MudAlert>
    }

    <MudPaper Class="pa-3 mb-3" Elevation="1">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="this.filterClientId" Label="Client id" Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="this.filterMergeOwnerId" Label="Merge id" Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudCheckBox @bind-Value="this.onlyOrphans" Label="Only orphans" T="bool" Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudCheckBox @bind-Value="this.onlyLarge" Label="Only large" T="bool" Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="2">
                <MudNumericField T="int" @bind-Value="this.largeThresholdMb" Label="> X MB" Dense="true" Min="1" Disabled="@(!this.onlyLarge)" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker @bind-Date="this.olderThan" Label="Older than" Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="this.ApplyFiltersAsync" Disabled="this.busy">Apply</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="this.ClearFiltersAsync" Disabled="this.busy" Class="ml-2">Clear</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-3" Elevation="1">
        <MudTable Items="this.items" Dense="true" Hover="true" Loading="this.busy">
            <HeaderContent>
                <MudTh>Token</MudTh>
                <MudTh>Uploaded (UTC)</MudTh>
                <MudTh align="right">Size</MudTh>
                <MudTh align="right">Ref</MudTh>
                <MudTh>Ready</MudTh>
                <MudTh>Client / Merge</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Token">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Style="max-width:260px; overflow:hidden; text-overflow:ellipsis;">@context.Token</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" OnClick="() => this.CopyTokenAsync(context.Token)" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Uploaded (UTC)">@context.UploadedUtc</MudTd>
                <MudTd DataLabel="Size" Align="Right">@this.FormatSize(context.Length)</MudTd>
                <MudTd DataLabel="Ref" Align="Right">@context.RefCount</MudTd>
                <MudTd DataLabel="Ready">@(context.Ready ? "Yes" : "No")</MudTd>
                <MudTd DataLabel="Client / Merge">
                    <MudText Typo="Typo.caption">@context.ClientId</MudText>
                    <MudText Typo="Typo.caption">@context.MergeOwnerId</MudText>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <div class="d-flex gap-1">
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => this.ViewManifestAsync(context.Token)" Disabled="this.busy">Manifest</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="() => this.DownloadAsync(context.Token)" Disabled="this.busy">Download</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="() => this.DeleteAsync(context.Token, context.RefCount == 0)" Disabled="this.busy">Delete</MudButton>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>

        <div class="d-flex justify-space-between align-center mt-3 flex-wrap gap-2">
            <MudText Typo="Typo.caption">Total: @this.total</MudText>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Disabled="@(!this.canPrev || this.busy)" OnClick="this.PrevPageAsync">Prev</MudButton>
                <MudButton Variant="Variant.Outlined" Disabled="@(!this.canNext || this.busy)" OnClick="this.NextPageAsync">Next</MudButton>
            </div>
        </div>
    </MudPaper>
</MudContainer>
