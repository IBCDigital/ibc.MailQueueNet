# Copy this file to `.env` (same folder as `docker-compose.yml`) and set values for your host.
#
# On Linux/WSL:
#   HOST_UID=$(id -u)
#   HOST_GID=$(id -g)
#
# On macOS:
#   HOST_UID=$(id -u)
#   HOST_GID=$(id -g)
#
# On Windows (Docker Desktop):
#   You can usually omit this file, or set HOST_UID/HOST_GID to 1000/1000 when using WSL bind mounts.
#
# These values are used by docker-compose `user: "${HOST_UID}:${HOST_GID}"` so bind-mounted files
# (logs, queue folders, work folders, DB files) are created with the same ownership as your dev user.
# This prevents `Permission denied` when switching between Docker and local/WSl debugging.

HOST_UID=1000
HOST_GID=1000
