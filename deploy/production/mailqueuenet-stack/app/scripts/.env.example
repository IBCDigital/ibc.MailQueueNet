# Helper script defaults for the production stack.
# Copy this file to '.env' (same folder) and fill in values.
# NOTE: scripts/.env is ignored by git (credentials/secrets).

# SSH / production server
PRODUCTION_SERVER=
PRODUCTION_USER=ibcdigital
PRODUCTION_REMOTE_PATH=/wwwroot/wwwdocs/mailqueuenet-stack
PRODUCTION_UPLOAD_PATH=/tmp/mailqueuenet-stack-upload

# Privilege mode used for commands that write to PRODUCTION_REMOTE_PATH or run Docker Compose.
# Use 'none' when PRODUCTION_USER owns PRODUCTION_REMOTE_PATH and can run Docker directly.
# Use 'sudo' when ibcdigital has passwordless sudo for deployment commands.
# Use 'sudo-password' to pass PRODUCTION_PRIVILEGE_PASSWORD to sudo -S.
# Use 'su' when you prefer to type the root password interactively.
PRODUCTION_PRIVILEGE_MODE=none
PRODUCTION_PRIVILEGE_PASSWORD=

# Optional: enable non-interactive SSH/SCP when using PuTTY tools (plink/pscp) or sshpass.
# Leave blank to be prompted or to rely on SSH keys.
PRODUCTION_SSH_PASSWORD=

# Container registry used by push-images-to-registry.ps1
DOCKER_REGISTRY=docker-hub.internal.ibc.com.au
DOCKER_TAG=latest
DOCKER_USERNAME=
DOCKER_PASSWORD=
