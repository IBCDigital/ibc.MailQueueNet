# MailQueueNet.Service (production)
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5000

# Production may run behind a TLS-terminating reverse proxy and use HTTP internally.

# Persistent paths (bind-mounted at /data)
LoggingSettings__LogFilesFolder=/data/logs/mailqueueservice
MAILQUEUENET_CONFIG_DIR=/data/config
queue__queue_folder=/data/mail/queue
queue__failed_folder=/data/mail/failed
queue__mail_merge_queue_folder=/data/mail/merge
Attachments__Path=/data/attachments
Attachments__IndexDbPath=/data/db/attachment_index.db
mailforge__dispatcher__stateDbPath=/data/db/dispatcher_state.db

# MailForge integration
mailforge__dispatcher__enabled=true
mailforge__dispatcher__workerAddresses__0=http://mailforge:5002

# SMTP delivery (production)
queue__mail_service_type=smtp
queue__smtp__server=
queue__smtp__port=25
queue__smtp__ssl=false
queue__smtp__authentication=false
queue__smtp__username=
queue__smtp__password=

# Staging mail routing should remain disabled in production.
StagingMailRouting__Enabled=false
StagingMailRouting__ForceMailpitOnly=true
StagingMailRouting__SubjectPrefix=
StagingMailRouting__Mailpit__Host=
StagingMailRouting__Mailpit__Port=1025
StagingMailRouting__Mailpit__RequiresSsl=false
StagingMailRouting__Mailpit__RequiresAuthentication=false
StagingMailRouting__RealSmtp__Host=
StagingMailRouting__RealSmtp__Port=25
StagingMailRouting__RealSmtp__RequiresSsl=false
StagingMailRouting__RealSmtp__RequiresAuthentication=false
StagingMailRouting__RealSmtp__Username=
StagingMailRouting__RealSmtp__Password=

# Security
Security__SharedClientSecret=change-me

# Internal admin shared-secret authentication.
Security__AdminSharedSecret=

# Replay protection required: clients must include x-ts and x-nonce with admin shared-secret calls.
