# Helper script defaults for the staging stack.
# Copy this file to '.env' (same folder) and fill in values.
# NOTE: scripts/.env is ignored by git (credentials/secrets).

# SSH / staging server
STAGING_SERVER=docker-dev-internal.ibc.com.au
STAGING_USER=root
STAGING_REMOTE_PATH=/wwwroot/wwwdocs/mailqueuenet-stack

# Optional: enable non-interactive SSH/SCP when using PuTTY tools (plink/pscp) or sshpass.
# Leave blank to be prompted or to rely on SSH keys.
STAGING_SSH_PASSWORD=

# Container registry used by push-images-to-registry.ps1
DOCKER_REGISTRY=docker-hub.internal.ibc.com.au
DOCKER_TAG=latest
DOCKER_USERNAME=
DOCKER_PASSWORD=
