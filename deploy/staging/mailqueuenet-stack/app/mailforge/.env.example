# MailForge (staging)
ASPNETCORE_ENVIRONMENT=Staging
ASPNETCORE_URLS=http://0.0.0.0:5002

# MailQueueNet integration
MailQueue__Address=http://mailqueuenet-service:5000
MailQueue__ClientId=MailForge Worker
MailQueue__SharedSecret=change-me

# Persistent paths (bind-mounted at /data)
mailforge__jobWorkRoot=/data/work
MAILFORGE_BATCH_FOLDER=/data/batches
MailForge__FenceDbPath=/data/db/dispatch_fence.db
FileLogging__Path=/data/logs/mailforge

# Internal admin shared-secret authentication (HTTP only; no client certs).
Security__AdminSharedSecret=

# Replay protection required: clients must include x-ts and x-nonce with admin shared-secret calls.
