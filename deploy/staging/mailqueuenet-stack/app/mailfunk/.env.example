# MailFunk (staging)
ASPNETCORE_ENVIRONMENT=Staging
ASPNETCORE_URLS=http://0.0.0.0:5004

# Service addresses (Docker network)
MailService__BaseAddress=http://mailqueuenet-service:5000
MailForge__BaseAddress=http://mailforge:5002

# Admin client certificate (optional).
# Note: If MailFunk calls the services over HTTP (TLS terminated at the proxy), client certificates cannot be used.
AdminClientCert__Thumbprint=
AdminClientCert__Path=
AdminClientCert__Password=

# Persistent paths (bind-mounted at /data)
LoggingSettings__LogFilesFolder=/data/logs/mailfunk

# Azure AD (set values for staging)
AzureAd__TenantId=
AzureAd__ClientId=
AzureAd__ClientSecret=

# Internal admin shared-secret authentication (HTTP only; no client certs).
Security__AdminSharedSecret=
Security__AdminClientId=MailFunk

# Replay protection headers are generated automatically by MailFunk when AdminSharedSecret is set.
